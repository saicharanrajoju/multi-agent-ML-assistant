# ── Groq (required — add up to 3 keys for rate-limit rotation) ────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_2=your_groq_api_key_2        # optional but recommended
GROQ_API_KEY_3=your_groq_api_key_3        # optional

# ── Alternative LLM providers (only needed if LLM_PROVIDER is changed) ────────
NVIDIA_API_KEY=your_nvidia_api_key
GEMINI_API_KEY=your_gemini_api_key
TOGETHER_API_KEY=your_together_api_key

# ── LLM provider selection ─────────────────────────────────────────────────────
# Options: "groq" | "nvidia" | "gemini" | "together"
LLM_PROVIDER=groq

# ── E2B sandbox (required) ────────────────────────────────────────────────────
E2B_API_KEY=your_e2b_api_key

# ── LangSmith observability (optional) ────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=ml-agent-assistant
LANGSMITH_TRACING=true
